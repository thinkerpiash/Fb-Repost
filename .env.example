# =============================================
# Facebook Repost Bot — Configuration
# =============================================

# Source Page (where posts will be fetched from)
# Can be the page's username or numeric ID
SOURCE_PAGE_ID=source_page_username_or_id

# (Optional) RSS Feed URL of the Source Page
# Use this if you do not manage the source page to bypass Facebook API restrictions.
# You can generate this using free tools like RSS.app or FetchRSS.
# If this is set, the bot will fetch posts from the RSS feed instead of using the Graph API.
SOURCE_RSS_FEED_URL=


# Destination Page (where posts will be published)
DEST_PAGE_ID=your_destination_page_id

# Destination Page's Access Token
# Get this from Meta Developer Console > Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
DEST_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token

# How often to check for new posts (in minutes)
CHECK_INTERVAL_MINUTES=15

# How many posts to check per fetch (max 100)
POSTS_PER_FETCH=10

# Log level: error | warn | info | debug
LOG_LEVEL=info
